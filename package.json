{
  "name": "talent-rediscovery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"pnpm --filter @recollect/admin dev\" \"pnpm --filter @recollect/api dev\"",
    "dev:client": "pnpm --filter @recollect/admin dev",
    "dev:server": "pnpm --filter @recollect/api dev",
    "build": "pnpm --filter @recollect/domain check && pnpm --filter @recollect/api check && pnpm --filter @recollect/admin build",
    "preview": "pnpm --filter @recollect/admin preview",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "pnpm --filter @recollect/domain check && pnpm --filter @recollect/api check && pnpm --filter @recollect/admin check && vitest run",
    "check:csv": "vitest run tests/csv-candidate-records.test.ts",
    "check:search-criteria": "vitest run tests/search-criteria.test.ts",
    "check:shortlist": "vitest run tests/shortlist-matches.test.ts",
    "check:message-draft": "vitest run tests/message-draft.test.ts",
    "check:app-store": "vitest run tests/app-store-session.test.ts",
    "check:api-boundary": "vitest run tests/api-boundary.test.ts"
  },
  "dependencies": {
    "@recollect/api": "workspace:*",
    "@recollect/domain": "workspace:*",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.184",
    "@hono/node-server": "^2.0.2",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.182",
    "hono": "^4.12.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
