{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^check"],
      "outputs": ["dist/**"]
    },
    "@recollect/api#build": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false
    }
  }
}
